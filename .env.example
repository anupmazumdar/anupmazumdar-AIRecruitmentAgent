# ============================================================
# TalentAI Recruitment — Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit your actual .env file to Git
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── SUPERADMIN DEFAULT LOGIN ───────────────────────────────
SUPERADMIN_NAME=TalentAI Admin
SUPERADMIN_EMAIL=anupmazumdar987@gmail.com
SUPERADMIN_PASSWORD=Anup@2610

# ── AI — OPENROUTER (Recommended, free tier available) ──────
# Sign up free: https://openrouter.ai/
# Get key:      https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use (free options — no billing needed):
#   mistralai/mistral-7b-instruct:free   ← default
#   google/gemma-3-27b-it:free
#   meta-llama/llama-3.1-8b-instruct:free
#   deepseek/deepseek-r1:free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Optional per-endpoint OpenRouter model overrides
# OPENROUTER_MODEL_QUIZ=
# OPENROUTER_MODEL_RESUME=
# OPENROUTER_MODEL_INTERVIEW=
# OPENROUTER_MODEL_CAREER=

# ── OTHER AI KEYS (optional — OpenRouter takes priority) ────
# GOOGLE_GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_PROVIDER=gemini

# Optional global model overrides per provider
# GOOGLE_GEMINI_MODEL=gemini-pro
# OPENAI_MODEL=gpt-3.5-turbo
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional per-endpoint model overrides per provider
# GOOGLE_GEMINI_MODEL_QUIZ=
# GOOGLE_GEMINI_MODEL_RESUME=
# GOOGLE_GEMINI_MODEL_INTERVIEW=
# GOOGLE_GEMINI_MODEL_CAREER=
# OPENAI_MODEL_QUIZ=
# OPENAI_MODEL_RESUME=
# OPENAI_MODEL_INTERVIEW=
# OPENAI_MODEL_CAREER=
# ANTHROPIC_MODEL_QUIZ=
# ANTHROPIC_MODEL_RESUME=
# ANTHROPIC_MODEL_INTERVIEW=
# ANTHROPIC_MODEL_CAREER=

# Request timeout for AI calls in milliseconds (minimum enforced: 3000)
AI_REQUEST_TIMEOUT_MS=25000

# ── GOOGLE CLOUD STORAGE (optional) ─────────────────────────
# Leave blank to use local in-memory storage
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_BUCKET_NAME=
# GOOGLE_APPLICATION_CREDENTIALS=

# ── FRONTEND ─────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001

# ============================================================
# TalentAI Recruitment — Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit your actual .env file to Git
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── AI — OPENROUTER (Recommended, free tier available) ──────
# Sign up free: https://openrouter.ai/
# Get key:      https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use (free options — no billing needed):
#   mistralai/mistral-7b-instruct:free   ← default
#   google/gemma-3-27b-it:free
#   meta-llama/llama-3.1-8b-instruct:free
#   deepseek/deepseek-r1:free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ── OTHER AI KEYS (optional — OpenRouter takes priority) ────
# GOOGLE_GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_PROVIDER=gemini

# ── GOOGLE CLOUD STORAGE (optional) ─────────────────────────
# Leave blank to use local in-memory storage
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_BUCKET_NAME=
# GOOGLE_APPLICATION_CREDENTIALS=

# ── FRONTEND ─────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001
